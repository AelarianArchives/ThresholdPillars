#!/bin/bash
# Aelarian Archives — Pre-commit enforcement hook
# Source: hooks/pre-commit (tracked)
# Install: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Re-install any time this file is updated.

set -e

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "Running pre-commit enforcement checks..."
WARNINGS=0

# ---------------------------------------------------------------
# CHECK 1 — Credential patterns (F32)
# Hard block. Commit does not proceed.
# ---------------------------------------------------------------
echo "  [1/7] Credential scan..."

CREDENTIAL_PATTERNS="B2_KEY_ID\s*=\s*['\"][^'\"]{5}|B2_APP_KEY\s*=\s*['\"][^'\"]{5}|password\s*=\s*['\"][^'\"]{3}|api_key\s*=\s*['\"][^'\"]{3}|app_key\s*=\s*['\"][^'\"]{3}|secret\s*=\s*['\"][^'\"]{3}"

for FILE in $STAGED_FILES; do
    # Skip .md files — documentation, not executable code
    if echo "$FILE" | grep -qE "\.md$"; then
        continue
    fi
    # Block .env from being staged at all
    if echo "$FILE" | grep -qE "(^|/)\.env(\.|$)"; then
        echo ""
        echo "  BLOCKED: .env file staged for commit: $FILE"
        echo "  .env must never be committed. Add to .gitignore."
        exit 1
    fi
    # Scan file content for credential patterns
    if git show ":$FILE" 2>/dev/null | grep -qiP "$CREDENTIAL_PATTERNS" 2>/dev/null; then
        echo ""
        echo "  BLOCKED: Credential pattern detected in: $FILE"
        echo "  Move credentials to .env and read via os.environ.get()."
        echo "  See GITHUB_PROTOCOL.md section 5."
        exit 1
    fi
done

echo "  PASS"

# ---------------------------------------------------------------
# CHECK 2 — Function naming: technical verb required (F14)
# Warning only. Promotes to hard block when eslint is active (build phase).
# Covers function keyword declarations in .js files only.
# Arrow functions and class methods: covered by eslint at build phase.
# Rule: function names describe what code does mechanically (verb first).
# Canonical names belong on the things themselves, not on the actions.
# ---------------------------------------------------------------
echo "  [2/7] Function naming check..."

TECH_VERBS="^(get|set|create|update|delete|fetch|load|save|store|build|parse|validate|resolve|render|handle|init|reset|clear|check|run|start|stop|format|convert|find|add|remove|apply|process|compute|generate|read|write|sync|dispatch|emit|bind|register|configure|setup|teardown|serialize|decode|encode|transform|merge|filter|sort|map|compare|display|show|hide|open|close|connect|send|receive|push|pull|log|track|report|is|has|can|should|on|test|describe)"

CHECK2_WARNINGS=0
for FILE in $STAGED_FILES; do
    if echo "$FILE" | grep -qE "\.js$"; then
        if echo "$FILE" | grep -qE "(DOCS/|hooks/|_REFERENCE_ONLY/)"; then
            continue
        fi
        FUNC_NAMES=$(git show ":$FILE" 2>/dev/null | \
            grep -oE 'function [a-z][a-zA-Z0-9]*[[:space:]]*\(' | \
            grep -oE ' [a-z][a-zA-Z0-9]+' | \
            tr -d ' ') || true
        if [ -n "$FUNC_NAMES" ]; then
            VIOLATIONS=$(echo "$FUNC_NAMES" | grep -vE "$TECH_VERBS" 2>/dev/null) || true
            if [ -n "$VIOLATIONS" ]; then
                echo ""
                echo "  WARNING: Non-technical function name(s) in: $FILE"
                echo "$VIOLATIONS" | while IFS= read -r name; do
                    echo "    function ${name}() — name does not start with a technical verb"
                done
                echo "  Function names must describe what code does mechanically. See ENFORCEMENT.md F14."
                CHECK2_WARNINGS=$((CHECK2_WARNINGS + 1))
                WARNINGS=$((WARNINGS + 1))
            fi
        fi
    fi
done

if [ $CHECK2_WARNINGS -eq 0 ]; then
    echo "  PASS"
fi

# ---------------------------------------------------------------
# CHECK 3 — Lockfile consistency (F20)
# Hard block when frontend/package.json exists.
# Monorepo-aware: lockfile lives in frontend/, not project root.
# ---------------------------------------------------------------
echo "  [3/7] Lockfile check..."

if [ -f "frontend/package.json" ]; then
    if [ ! -f "frontend/package-lock.json" ]; then
        echo ""
        echo "  BLOCKED: frontend/package.json present but frontend/package-lock.json is missing."
        echo "  Run: cd frontend && npm ci (never npm install)"
        exit 1
    fi
    if echo "$STAGED_FILES" | grep -q "^frontend/package.json$"; then
        if ! echo "$STAGED_FILES" | grep -q "^frontend/package-lock.json$"; then
            echo ""
            echo "  BLOCKED: frontend/package.json staged without frontend/package-lock.json."
            echo "  Both must be committed together."
            exit 1
        fi
    fi
    echo "  PASS"
else
    echo "  SKIP (no frontend/package.json — applies when frontend exists)"
fi

# ---------------------------------------------------------------
# CHECK 4 — Sensitive file patterns (F32)
# Hard block.
# ---------------------------------------------------------------
echo "  [4/7] Sensitive file check..."

SENSITIVE_PATTERNS="(^|/)credentials|secrets\.(json|yml|yaml)|\.pem$|\.p12$|\.key$"

for FILE in $STAGED_FILES; do
    if echo "$FILE" | grep -qiE "$SENSITIVE_PATTERNS"; then
        echo ""
        echo "  BLOCKED: Sensitive file pattern detected: $FILE"
        echo "  This file type must not be committed."
        exit 1
    fi
done

echo "  PASS"

# ---------------------------------------------------------------
# CHECK 5 — Test suite (F06)
# Hard block if test suite exists and fails.
# Monorepo-aware: tests live in frontend/src/, run from frontend/.
# ---------------------------------------------------------------
echo "  [5/7] Test suite..."

if [ -f "frontend/package.json" ]; then
    TEST_FILES=$(find frontend/src \( -name "*.test.ts" -o -name "*.test.js" -o -name "*.spec.ts" -o -name "*.spec.js" \) 2>/dev/null)
    if [ -n "$TEST_FILES" ]; then
        if (cd frontend && npm test --silent 2>&1); then
            echo "  PASS"
        else
            echo ""
            echo "  BLOCKED: Test suite failed. Fix failing tests before committing."
            exit 1
        fi
    else
        echo "  SKIP (frontend exists but no test files found)"
    fi
else
    echo "  SKIP (no frontend/package.json — applies when frontend exists)"
fi

# ---------------------------------------------------------------
# CHECK 6 — Dead code and variable shadow detection (F15, F44)
# Monorepo-aware: frontend files (.js, .ts, .svelte) use frontend ESLint.
# Non-frontend .js files use root ESLint (if installed).
# Skips core/ (reference-only) and hooks/ (shell scripts).
# ---------------------------------------------------------------
echo "  [6/7] Dead code and shadow detection (eslint)..."

FRONTEND_LINT_FILES=$(echo "$STAGED_FILES" | grep -E "^frontend/.*\.(js|ts|svelte)$") || true
OTHER_JS_FILES=$(echo "$STAGED_FILES" | grep -E "\.js$" | grep -v "^frontend/" | grep -v "^_REFERENCE_ONLY/" | grep -v "^core/" | grep -v "^hooks/") || true

LINT_RAN=0

if [ -n "$FRONTEND_LINT_FILES" ]; then
    if [ ! -f "frontend/node_modules/.bin/eslint" ]; then
        echo ""
        echo "  BLOCKED: eslint not installed in frontend/. Required before frontend files can be committed."
        echo "  Run: cd frontend && npm ci"
        exit 1
    fi
    RELATIVE_FILES=$(echo "$FRONTEND_LINT_FILES" | sed 's|^frontend/||')
    ESLINT_EXIT=0
    ESLINT_OUTPUT=$(cd frontend && echo "$RELATIVE_FILES" | xargs node_modules/.bin/eslint 2>&1) || ESLINT_EXIT=$?
    if [ $ESLINT_EXIT -eq 1 ]; then
        echo ""
        echo "  BLOCKED: ESLint errors in frontend files:"
        echo "$ESLINT_OUTPUT"
        echo "  See ENFORCEMENT.md F15, F44."
        exit 1
    elif [ $ESLINT_EXIT -eq 2 ]; then
        echo ""
        echo "  BLOCKED: ESLint configuration error:"
        echo "$ESLINT_OUTPUT"
        exit 1
    fi
    LINT_RAN=1
fi

if [ -n "$OTHER_JS_FILES" ]; then
    if [ ! -f "node_modules/.bin/eslint" ]; then
        echo ""
        echo "  BLOCKED: eslint not installed at project root. Required before .js files outside frontend/ can be committed."
        exit 1
    fi
    ESLINT_EXIT=0
    ESLINT_OUTPUT=$(echo "$OTHER_JS_FILES" | xargs node_modules/.bin/eslint \
        --no-eslintrc \
        --rule '{"no-unused-vars": "error", "no-shadow": "error"}' \
        2>&1) || ESLINT_EXIT=$?
    if [ $ESLINT_EXIT -eq 1 ]; then
        echo ""
        echo "  BLOCKED: Dead code or variable shadowing detected:"
        echo "$ESLINT_OUTPUT"
        echo "  See ENFORCEMENT.md F15, F44."
        exit 1
    elif [ $ESLINT_EXIT -eq 2 ]; then
        echo ""
        echo "  BLOCKED: ESLint configuration error:"
        echo "$ESLINT_OUTPUT"
        exit 1
    fi
    LINT_RAN=1
fi

if [ $LINT_RAN -eq 0 ]; then
    echo "  SKIP (no lintable files staged)"
else
    echo "  PASS"
fi

# ---------------------------------------------------------------
# CHECK 7 — _REFERENCE_ONLY write guard
# Hard block. _REFERENCE_ONLY is a contaminated read-only snapshot.
# No file inside it is ever staged or committed.
# ---------------------------------------------------------------
echo "  [7/7] _REFERENCE_ONLY guard..."

for FILE in $STAGED_FILES; do
    if echo "$FILE" | grep -qE "^_REFERENCE_ONLY/"; then
        echo ""
        echo "  BLOCKED: Staged file is inside _REFERENCE_ONLY/: $FILE"
        echo "  _REFERENCE_ONLY is a read-only contaminated snapshot."
        echo "  No writes to this directory are permitted. See CLAUDE.md."
        exit 1
    fi
done

echo "  PASS"

# ---------------------------------------------------------------
# Result
# ---------------------------------------------------------------
echo ""
if [ $WARNINGS -gt 0 ]; then
    echo "Pre-commit checks complete. $WARNINGS warning(s) require review."
    echo "Commit is not blocked by warnings — but review before proceeding."
else
    echo "Pre-commit checks complete. All passed."
fi

exit 0
